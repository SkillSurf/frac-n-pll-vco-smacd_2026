library (dsm_and_freq_divider) {
  comment                        : "";
  delay_model                    : table_lookup;
  simulation                     : false;
  capacitive_load_unit (1,pF);
  leakage_power_unit             : 1pW;
  current_unit                   : "1uA";
  pulling_resistance_unit        : "1kohm";
  time_unit                      : "1ns";
  voltage_unit                   : "1v";
  library_features(report_delay_calculation);

  input_threshold_pct_rise : 50;
  input_threshold_pct_fall : 50;
  output_threshold_pct_rise : 50;
  output_threshold_pct_fall : 50;
  slew_lower_threshold_pct_rise : 20;
  slew_lower_threshold_pct_fall : 20;
  slew_upper_threshold_pct_rise : 80;
  slew_upper_threshold_pct_fall : 80;
  slew_derate_from_library : 1.0;


  nom_process                    : 1.0;
  nom_temperature                : -40.0;
  nom_voltage                    : 1.32;


  cell ("dsm_and_freq_divider") {
    area : 6363.096 
    is_macro_cell : true;
    pin("en") {
      direction : input;
      capacitance : 0.0030;
      timing() {
        related_pin : "sclk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.18105");
	}
	fall_constraint(scalar) {
          values("-0.16071");
	}
      }
      timing() {
        related_pin : "sclk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.25341");
	}
	fall_constraint(scalar) {
          values("0.22524");
	}
      }
    }
    pin("freq_in") {
      direction : input;
      clock : true;
      capacitance : 0.0057;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.00023");
	}
	cell_fall(scalar) {
          values("0.00021");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.00023");
	}
	cell_fall(scalar) {
          values("0.00021");
	}
      }
    }
    pin("freq_out") {
      direction : output;
      capacitance : 0.0005;
    }
    pin("rst") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "sclk";
        timing_type : hold_rising;
	fall_constraint(scalar) {
          values("-0.13334");
	}
      }
      timing() {
        related_pin : "sclk";
        timing_type : setup_rising;
	fall_constraint(scalar) {
          values("0.18751");
	}
      }
      timing() {
        related_pin : "freq_in";
        timing_type : hold_rising;
	fall_constraint(scalar) {
          values("-0.39020");
	}
      }
      timing() {
        related_pin : "freq_in";
        timing_type : setup_rising;
	fall_constraint(scalar) {
          values("0.40531");
	}
      }
    }
    pin("sclk") {
      direction : input;
      clock : true;
      capacitance : 0.0206;
      timing() {
        timing_sense : positive_unate;
        timing_type : min_clock_tree_path;
	cell_rise(scalar) {
          values("0.08477");
	}
	cell_fall(scalar) {
          values("0.09077");
	}
      }
      timing() {
        timing_sense : positive_unate;
        timing_type : max_clock_tree_path;
	cell_rise(scalar) {
          values("0.08505");
	}
	cell_fall(scalar) {
          values("0.09102");
	}
      }
    }
    pin("sdata") {
      direction : input;
      capacitance : 0.0032;
      timing() {
        related_pin : "sclk";
        timing_type : hold_rising;
	rise_constraint(scalar) {
          values("-0.04819");
	}
	fall_constraint(scalar) {
          values("-0.04117");
	}
      }
      timing() {
        related_pin : "sclk";
        timing_type : setup_rising;
	rise_constraint(scalar) {
          values("0.08334");
	}
	fall_constraint(scalar) {
          values("0.08885");
	}
      }
    }
  }

}

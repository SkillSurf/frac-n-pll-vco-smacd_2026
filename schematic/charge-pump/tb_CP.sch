C {lab_pin.sym} 1900 -910 3 1 {name=p7 sig_type=std_logic lab=DN}
C {simulator_commands.sym} 2220 -620 0 0 {name=TRAN only_toplevel=true 
value="
.param temp = 27
.options method=gear rshunt=1.0e12

.control

* Save required signals
save v(UP) v(DN) v(VCP) v(CTRL)

* Long transient simulation
tran 1n 6u

* Save raw waveform
write CP_tran.raw

* Plot transient waveform
plot v(UP) v(DN) v(VCP) v(CTRL)
plot v(CTRL)
plot i(Vloop)
plot v(vbp) v(vbn)

.endc
"
}
